# API Configuration
API_HOST=localhost
API_PORT=8000
RELOAD=True  # Set to False in production

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

#Database Configuration (Local Development) use any one local or cloud sql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Database configuration for Cloud SQL - PostgreSQL (production)
DB_USER=postgres
DB_PASSWORD=yourcloudpassword
DB_NAME=real_estate_db
CLOUD_SQL_CONNECTION_NAME=your-project:us-central1:your-instance
USE_PRIVATE_IP=true

# Database Pool Configuration
DB_POOL_MIN=5
DB_POOL_MAX=20

# Logging Configuration
LOG_LEVEL=INFO